// Generate rose_generated.rs by running this command using the same version of flatc as that listed
// in the Cargo.toml (i.e, the FlatBuffers compiler and the FlatBuffers library used when compiling
// this crate should be the same version).
//
// ```
// flatc --rust rose.fbs
// ```
// 
// TODO:
//   - data blocks with info about what functions own them (if any)
//   - source location for each instruction (if available)
//
// NOT PROVIDED DIRECTLY SINCE CAN BE COMPUTED FROM OTHER DATA
//   - address usage map (AUM)
//   - function ownership per instruction

namespace Rose.BinaryAnalysis.Serialization.FlatBuffers;
////////////////////////////////////////////////////////////////////////////////////////////////////
// Memory Map
////////////////////////////////////////////////////////////////////////////////////////////////////

// Accessibility bit flags that can be OR'd together.
enum Accessibility : ubyte {
    EXECUTABLE = 1,
    WRITABLE = 2,
    READABLE = 4,
    IMMUTABLE = 8,
    PRIVATE = 16
}

enum Endianness : ubyte {
    ORDER_UNSPECIFIED,
    ORDER_LSB,
    ORDER_MSB,
}

table Segment {
    address: uint64;
    bytes: [ubyte];
    accessibility: ubyte; // Accessibility bits OR'd together
    name: string; // optional
}

table MemoryMap {
    endianness: Endianness;
    segments: [Segment];
}

////////////////////////////////////////////////////////////////////////////////////////////////////
// Instructions
////////////////////////////////////////////////////////////////////////////////////////////////////

// One machine instruction.
table Instruction {
    address: uint64;
    bytes: [ubyte];
    mnemonic: string; // optional
    operands: string; // optional
}

// All known instructions. Every instruction has a unique address.
table InstructionList {
 instructions: [Instruction];
}

////////////////////////////////////////////////////////////////////////////////////////////////////
// Basic blocks
////////////////////////////////////////////////////////////////////////////////////////////////////

// A basic block is an non-empty, ordered list of instruction addresses. The address of a basic
// block is the address of its first instruction.
table BasicBlock {
    addresses: [uint64]; // addresses of contained instructions in execution order
}

// All known basic blocks.
table BasicBlockList {
    basic_blocks: [BasicBlock]; // list of basic blocks with unique starting addresses
}

////////////////////////////////////////////////////////////////////////////////////////////////////
// Functions
////////////////////////////////////////////////////////////////////////////////////////////////////

table Function {
    entry_addr: uint64;
    instructions: [uint64]; // non-empty instruction addresses belonging to this function
    name: string; // optional name for function
}

// List of all known functions.
table FunctionList {
    functions: [Function]; // list of functions with unique entry addresses
}

////////////////////////////////////////////////////////////////////////////////////////////////////
// Control flow graph.
////////////////////////////////////////////////////////////////////////////////////////////////////

enum CfgEdgePurpose : uint8 {
    FunctionCall,        // edge represents a function call
    FunctionTransfer,    // edge goes from one function to another, but not a call; e.g., tail call optimization
    FunctionReturn,      // return edge from a function to its caller(s)
    CallReturn,          // an edge from a calling location to where the function would return if it returns
    Normal,              // normal
}

// Data associated with a CFG edge.
table CfgEdgeData {
    purpose: CfgEdgePurpose;
}

// A CFG edge that points to an address. If the address is that of an instruction then the target
// will be a node in the CFG and a basic block with that address will exist in the BasicBlockList
// table. If the edge points to a non-instruction address, then the address will not be a node in
// the CFG nor will there be an instruction or basic block with that address.
table AddressTarget {
    address: uint64;
}

// An indeterminate target has no data. It's a pointer to an unknown location.
table IndeterminateTarget {}

// The target end of a CFG edge. CFG edges don't necessarily need to point to a node in the CFG,
// although they always originate from such a node.
union CfgEdgeTarget {
    AddressTarget,
    IndeterminateTarget
}
    
// An edge has a source, target, and data. The source is always a basic block address. The target
// does not necessarily need to be a node in the control flow graph, although it usually is.
table CfgEdge {
    src: uint64; // source address
    tgt: CfgEdgeTarget;
    data: CfgEdgeData;
}

// A CFG is represented explicitly by its edges. The union of the edge source addresses are the
// nodes of the CFG and are instruction addresses.
//
// Note that ROSE CFGs usually point to basic blocks rather than individual instructions, so when
// loading the CFG into ROSE you'll probably want to collapse nodes based on the `BasicBlockList`.
table Cfg {
    edges: [CfgEdge];
}
    
////////////////////////////////////////////////////////////////////////////////////////////////////
// Root of the entire document.
////////////////////////////////////////////////////////////////////////////////////////////////////

// Root object for the flatbuffers file. Every flatbuffers file will store exactly one of these
// objects at the top level, and nothing else.
table Root {
    memory_map: MemoryMap;
    instructions: InstructionList;
    basic_blocks: BasicBlockList;
    functions: FunctionList;
    cfg: Cfg;
}

